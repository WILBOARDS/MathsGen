# Firebase Configuration
# Copy this file to .env and fill with your Firebase credentials
# NEVER commit the .env file with real credentials!

# Get these values from Firebase Console → Project Settings → Your Apps → Web
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_APP_ID=1:YOUR_APP_ID:web:YOUR_WEB_APP_ID

# Application Configuration
VITE_APP_NAME=Math Question Randomizer
VITE_APP_ENVIRONMENT=production
VITE_APP_VERSION=1.0.0

# Optional: Google Analytics
VITE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Optional: Google AdSense
VITE_ADS_ENABLED=true
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_LAYOUT_TOP=1234567890
VITE_ADSENSE_SLOT_LAYOUT_BOTTOM=1234567890
VITE_ADSENSE_SLOT_LEADERBOARD_INLINE=1234567890
VITE_ADSENSE_SLOT_PROFILE_INLINE=1234567890
VITE_ADSENSE_SLOT_ANALYTICS_INLINE=1234567890
VITE_ADSENSE_SLOT_PUBLIC_FOOTER=1234567890

# Optional: Cloudflare Turnstile (strict tutor verification)
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAAYOUR_SITE_KEY
CLOUDFLARE_TURNSTILE_SECRET=0x4AAAAAAYOUR_SECRET_KEY

# Optional: Resend auth email sender (Cloud Functions)
# Store RESEND_API_KEY in Firebase Functions Secrets Manager (do not put real value in .env)
RESEND_FROM_EMAIL=MathQuizzizz <no-reply@yourdomain.com>

# Optional: Multi-provider AI fallback (Gemini -> Ollama -> OpenRouter cycling)
# Secrets: OPENROUTER_API_KEY should be stored in Firebase Functions Secrets Manager.
AI_FALLBACK_MAX_ATTEMPTS=9
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TUTOR_MODEL=qwen2.5:7b-instruct
OLLAMA_IMAGE_MODEL=qwen2.5:7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TUTOR_MODEL=google/gemma-3-27b-it:free
OPENROUTER_IMAGE_MODEL=google/gemma-3-27b-it:free
OPENROUTER_SITE_URL=https://mathquizzizz.web.app
OPENROUTER_APP_NAME=MathQuizzizz
