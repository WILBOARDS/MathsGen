  "dependencies": {
    "@firebase/vertexai": "^1.2.4",
    "firebase": "^11.10.0",
    "framer-motion": "^12.34.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-router-dom": "^7.13.0",
