{
  "name": "math-question-randomizer",
  "version": "1.0.0",
  "description": "Professional full-stack math learning application with Firebase backend",
  "type": "module",
  "main": "public/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preflight:firebase": "node tools/firebase-preflight.mjs",
    "preflight:firebase:strict": "node tools/firebase-preflight.mjs --strict",
    "deploy:firebase": "firebase deploy",
    "local-hostd": "node tools/serve-local-hostd.mjs",
    "admin:miniapp": "npm run local-hostd",
    "analytics": "node tools/view-analytics.js",
    "analytics:7d": "node tools/view-analytics.js --range=7",
    "analytics:30d": "node tools/view-analytics.js --range=30",
    "analytics:errors": "node tools/view-analytics.js --category=errors",
    "analytics:vitals": "node tools/view-analytics.js --category=webVitals",
    "analytics:feedback": "node tools/view-analytics.js --category=feedback",
    "secret:scan": "node tools/secret-scan.mjs",
    "secret:scan:staged": "node tools/secret-scan.mjs --staged",
    "hooks:install": "node tools/install-hooks.mjs",
    "test": "node --test tests/*.test.js"
